{
  "expo": {
    "name": "SecureSproutExpo",
    "slug": "SecureSproutExpo",
    "scheme": "securesprout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/photo.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.securesprout.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "QUERY_ALL_PACKAGES"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA1B2C3D4E5F6G7H8I9J0K1L2M3N4O5P6Q"
        }
      }
    },
    "web": {
      "favicon": "./assets/photo.png"
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-community/datetimepicker",
        "expo-location"
      ],
      "expo-background-task",
      [
        "expo-splash-screen",
        {
          "image": "./assets/photo.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ]
  }
}